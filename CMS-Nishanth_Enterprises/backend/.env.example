# Server
NODE_ENV=development
PORT=4000

# CORS
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cmsdb?sslmode=disable

# JWT
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# Login credentials (mock/env-based)
AUTH_ADMIN_EMAIL=admin@example.com

# Preferred (production): hashed password
# Generate hash:
# node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
AUTH_ADMIN_PASSWORD_HASH=$2a$10$REPLACE_WITH_HASH

# Local fallback (do not use in production)
# AUTH_ADMIN_PASSWORD=YOUR_PASSWORD

# File uploads (page images). Default: ./assets (created on startup)
# ASSETS_ROOT=./assets

